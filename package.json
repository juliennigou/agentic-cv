{
  "name": "agentic-cv",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @agentic-cv/db db:generate",
    "db:migrate": "pnpm --filter @agentic-cv/db db:migrate",
    "scrape:business-france": "pnpm --filter @agentic-cv/worker scrape:business-france"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}

