{
  "name": "agentic-cv",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "ci:local": "pnpm db:generate && pnpm typecheck && pnpm lint && pnpm format:check",
    "debug:search": "pnpm --filter @agentic-cv/worker debug:search",
    "dev": "turbo dev",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:uninstall": "git config --unset core.hooksPath",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @agentic-cv/db db:generate",
    "db:migrate": "pnpm --filter @agentic-cv/db db:migrate",
    "db:deploy": "pnpm --filter @agentic-cv/db db:deploy",
    "pipeline:job-offers": "pnpm --filter @agentic-cv/worker pipeline:job-offers",
    "scrape:business-france": "pnpm --filter @agentic-cv/worker scrape:business-france",
    "structure:job-offers": "pnpm --filter @agentic-cv/worker structure:job-offers",
    "embed:job-offers": "pnpm --filter @agentic-cv/worker embed:job-offers",
    "match:job-offers": "pnpm --filter @agentic-cv/worker match:job-offers"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@next/eslint-plugin-next": "^15",
    "@types/node": "^22.10.2",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "globals": "^15",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8"
  }
}
