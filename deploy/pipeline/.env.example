# --- Base de données Supabase (pooler, IPv4) ---
# Dashboard Supabase → Connect :
#   DATABASE_URL = "Transaction pooler" (port 6543)
#   DIRECT_URL   = "Session pooler"     (port 5432, utilisé par les migrations)
# Remplace [REF], [REGION] et [PASSWORD] par les valeurs de ton projet.
DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# --- LiteLLM ---
# Même valeur que LITELLM_MASTER_KEY du proxy (deploy/litellm/.env).
# LITELLM_BASE_URL est fixé dans docker-compose.yml (http://litellm:4000/v1).
LITELLM_API_KEY=

# Modèles exposés par le proxy (doivent matcher deploy/litellm/config.yaml).
LITELLM_EMBEDDING_MODEL=text-embedding-3-small
LITELLM_STRUCTURING_MODEL=deepseek-chat
LITELLM_RESUME_MODEL=deepseek-chat
