# Clé maître du proxy : toute requête doit la présenter. Génère une valeur forte,
# ex. `openssl rand -hex 32`. C'est cette valeur que les consommateurs mettent
# dans LITELLM_API_KEY (cron, web app…).
LITELLM_MASTER_KEY=

# Clés upstream des providers réels (jamais exposées aux clients).
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
