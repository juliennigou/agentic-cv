generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ScrapeRunStatus {
  running
  skipped
  success
  partial_success
  failed
}

enum UserDocumentType {
  base_resume
  tailored_resume
  cover_letter
  other
}

enum ApplicationStatus {
  saved
  unread
  read
  to_apply
  in_progress
  applied
  completed
  interview
  rejected
  accepted
}

enum ApplicationArtifactKind {
  targeted_resume
  cover_letter
  recruiter_message
}

enum ApplicationArtifactStatus {
  draft
  pasted
  validated
}

model UserProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  firstName       String?  @map("first_name")
  lastName        String?  @map("last_name")
  phone           String?
  location        String?
  targetRoles     String[] @default([]) @map("target_roles")
  targetCountries String[] @default([]) @map("target_countries")
  skills          String[] @default([])
  languages       String[] @default([])
  // CV structuré (éducation, expériences, projets…) extrait du PDF déposé.
  // Forme validée par `resumeSchema` (@agentic-cv/shared) à la frontière.
  resumeData      Json?    @map("resume_data")
  // Embedding sémantique du profil (1536 dim) ; accès uniquement via $queryRaw/$executeRaw.
  embedding       Unsupported("vector(1536)")?
  // Horodatage du dernier calcul d'embedding ; profil à ré-embarquer quand
  // `updated_at > embedding_updated_at` (ou l'un des deux est NULL).
  embeddingUpdatedAt DateTime? @map("embedding_updated_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  documents    UserDocument[]
  savedJobs    SavedJob[]
  applications Application[]
  matches      JobMatch[]

  @@map("user_profiles")
}

model UserDocument {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  type        UserDocumentType
  fileName    String           @map("file_name")
  storagePath String           @map("storage_path")
  mimeType    String           @map("mime_type")
  sizeBytes   Int              @map("size_bytes")
  checksum    String?
  createdAt   DateTime         @default(now()) @map("created_at")

  user UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@map("user_documents")
}

model JobOffer {
  id                 String                      @id @default(uuid()) @db.Uuid
  source             String
  externalId         String?                     @map("external_id")
  sourceUrl          String                      @map("source_url")
  title              String
  companyName        String?                     @map("company_name")
  country            String?
  // Code pays ISO alpha-2 (depuis raw_data.countryId) ; clé du filtre géo / régions.
  countryCode        String?                     @map("country_code")
  city               String?
  contractType       String?                     @map("contract_type")
  durationMonths     Int?                        @map("duration_months")
  salary             String?
  description        String
  // Présentation de l'entreprise, séparée de la mission (exclue de l'embedding).
  companyDescription String?                     @map("company_description")
  // true = présentation générée par le LLM (entreprise connue) faute de bloc
  // société dans l'offre ; affichée avec un badge « IA » côté UI.
  companyDescriptionGenerated Boolean            @default(false) @map("company_description_generated")
  requirements       String?
  publishedAt        DateTime?                   @map("published_at")
  expiresAt          DateTime?                   @map("expires_at")
  scrapedAt          DateTime                    @map("scraped_at")
  firstSeenAt        DateTime                    @default(now()) @map("first_seen_at")
  lastSeenAt         DateTime                    @default(now()) @map("last_seen_at")
  contentHash        String                      @map("content_hash")
  rawData            Json                        @map("raw_data")
  // Horodatage de la passe de structuration LLM (sépare mission ↔ entreprise).
  // NULL = à (re)structurer ; remis à NULL quand le contenu change.
  structuredAt       DateTime?                   @map("structured_at")
  // Embedding sémantique (1536 dim) ; accès uniquement via $queryRaw/$executeRaw.
  embedding          Unsupported("vector(1536)")?
  // Vecteur full-text (français) titre + mission + entreprise. Colonne GENERATED
  // ALWAYS AS … STORED (cf. migration 20260605230000_job_offer_search) : Prisma ne
  // sait pas exprimer le GENERATED, on la déclare en Unsupported pour aligner le
  // schéma avec la base ; accès uniquement via $queryRaw/$executeRaw.
  fts                Unsupported("tsvector")?
  isActive           Boolean                     @default(true) @map("is_active")
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")

  savedJobs    SavedJob[]
  applications Application[]
  matches      JobMatch[]

  @@unique([source, externalId])
  @@unique([source, sourceUrl])
  @@index([source, isActive])
  @@index([country])
  @@index([countryCode])
  @@index([publishedAt])
  @@map("job_offers")
}

model ScrapeRun {
  id                String          @id @default(uuid()) @db.Uuid
  source            String
  status            ScrapeRunStatus
  startedAt         DateTime        @default(now()) @map("started_at")
  finishedAt        DateTime?       @map("finished_at")
  offersFound       Int             @default(0) @map("offers_found")
  offersCreated     Int             @default(0) @map("offers_created")
  offersUpdated     Int             @default(0) @map("offers_updated")
  offersUnchanged   Int             @default(0) @map("offers_unchanged")
  offersDeactivated Int             @default(0) @map("offers_deactivated")
  offersFailed      Int             @default(0) @map("offers_failed")
  errorMessage      String?         @map("error_message")

  @@index([source, startedAt])
  @@map("scrape_runs")
}

model ScrapeLock {
  source    String   @id
  runId     String?  @map("run_id") @db.Uuid
  lockedAt  DateTime @default(now()) @map("locked_at")
  expiresAt DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("scrape_locks")
}

model SavedJob {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  jobOfferId String   @map("job_offer_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  user     UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  jobOffer JobOffer    @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)

  @@unique([userId, jobOfferId])
  @@map("saved_jobs")
}

model JobMatch {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  jobOfferId String   @map("job_offer_id") @db.Uuid
  // Similarité cosinus 0–1 (1 - distance) entre embedding profil et embedding offre.
  score      Float
  createdAt  DateTime @default(now()) @map("created_at")

  user     UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  jobOffer JobOffer    @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)

  @@unique([userId, jobOfferId])
  @@index([userId, createdAt])
  @@map("job_matches")
}

model Application {
  id                    String            @id @default(uuid()) @db.Uuid
  userId                String            @map("user_id") @db.Uuid
  jobOfferId            String            @map("job_offer_id") @db.Uuid
  status                ApplicationStatus @default(unread)
  notes                 String?
  // URL de la conversation ChatGPT (ressaisie par l'utilisateur pour la rouvrir).
  chatgptConversationUrl String?          @map("chatgpt_conversation_url")
  // Horodatage de validation du dossier ; NULL = brouillon, sinon « validée ».
  validatedAt           DateTime?         @map("validated_at")
  appliedAt             DateTime?         @map("applied_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  user      UserProfile           @relation(fields: [userId], references: [userId], onDelete: Cascade)
  jobOffer  JobOffer              @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)
  artifacts ApplicationArtifact[]

  @@unique([userId, jobOfferId])
  @@map("applications")
}

model ApplicationArtifact {
  id            String                    @id @default(uuid()) @db.Uuid
  applicationId String                    @map("application_id") @db.Uuid
  kind          ApplicationArtifactKind
  // Contenu texte recollé depuis ChatGPT (CV ciblé / lettre / message).
  contentText   String?                   @map("content_text")
  status        ApplicationArtifactStatus @default(draft)
  validatedAt   DateTime?                 @map("validated_at")
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, kind])
  @@index([applicationId])
  @@map("application_artifacts")
}
