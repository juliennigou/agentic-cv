DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agentic_cv"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/agentic_cv"
NEXT_PUBLIC_SUPABASE_URL=""
# Nouvelle clé publique Supabase recommandée. En fallback, l'app accepte aussi l'anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Réservé aux tâches serveur/admin futures. Ne jamais exposer côté navigateur.
SUPABASE_SERVICE_ROLE_KEY=""
# Embeddings sémantiques des offres (Google AI Studio, free tier). Côté serveur uniquement.
GOOGLE_AI_API_KEY=""
# Optionnel : surcharge du modèle d'embedding (défaut : gemini-embedding-001).
GEMINI_EMBEDDING_MODEL=""
# Optionnel : surcharge du modèle de structuration LLM (défaut : gemini-2.5-flash-lite,
# ~1000 req/jour en free tier ; les modèles plus récents sont plafonnés bien plus bas).
GEMINI_STRUCTURING_MODEL=""
