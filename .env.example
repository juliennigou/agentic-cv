DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agentic_cv"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/agentic_cv"
NEXT_PUBLIC_SUPABASE_URL=""
# Nouvelle clé publique Supabase recommandée. En fallback, l'app accepte aussi l'anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Réservé aux tâches serveur/admin futures. Ne jamais exposer côté navigateur.
SUPABASE_SERVICE_ROLE_KEY=""
# Proxy LiteLLM OpenAI-compatible. Côté serveur uniquement.
# Exemple local : http://localhost:4000/v1
LITELLM_BASE_URL=""
# Optionnel si le proxy LiteLLM est protégé par une clé.
LITELLM_API_KEY=""
# Optionnel : modèle de structuration (défaut : deepseek/deepseek-chat).
LITELLM_STRUCTURING_MODEL=""
# Optionnel : modèle d'embedding 768 dimensions (défaut : openai/text-embedding-3-small).
LITELLM_EMBEDDING_MODEL=""
